<Page
    x:Class="DismSharp.UI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="仪表盘"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <!-- 去掉加载遮罩，改为渐进式显示 -->
    <ScrollViewer Margin="24" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- 标题 -->
            <TextBlock Text="仪表盘" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="系统总览" FontSize="14" Margin="0,4,0,20" Opacity="0.6" />

            <!-- 系统信息 + 硬件信息 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 操作系统信息 -->
                <ui:CardControl Grid.Column="0">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="操作系统" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,12" />
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="系统" Opacity="0.6" />
                                <TextBlock Grid.Column="1" Text="{Binding OsName}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="版本号" Opacity="0.6" />
                                <TextBlock Grid.Column="1" Text="{Binding OsBuild}" />
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="架构" Opacity="0.6" />
                                <TextBlock Grid.Column="1" Text="{Binding Architecture}" />
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="计算机名" Opacity="0.6" />
                                <TextBlock Grid.Column="1" Text="{Binding MachineName}" />
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="用户名" Opacity="0.6" />
                                <TextBlock Grid.Column="1" Text="{Binding UserName}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="运行时间" Opacity="0.6" />
                                <TextBlock Grid.Column="1" Text="{Binding Uptime}" />
                            </Grid>
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <!-- 硬件信息 -->
                <ui:CardControl Grid.Column="2">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="硬件信息" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,12" />
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="处理器" Opacity="0.6" />
                                <TextBlock Grid.Column="1" Text="{Binding CpuName}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="总内存" Opacity="0.6" />
                                <TextBlock Grid.Column="1" Text="{Binding TotalMemory}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="可用内存" Opacity="0.6" />
                                <TextBlock Grid.Column="1" Text="{Binding AvailableMemory}" />
                            </Grid>
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>
            </Grid>

            <!-- 磁盘信息 -->
            <TextBlock Text="磁盘信息" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,8" />
            <ItemsControl ItemsSource="{Binding DiskDrives}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Background="{DynamicResource CardBackground}"
                            CornerRadius="4"
                            Padding="16,12"
                            Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DriveLetter}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding VolumeName}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <ProgressBar
                                    Grid.Column="1"
                                    Value="{Binding UsagePercent}"
                                    Maximum="100"
                                    Height="16"
                                    Margin="12,0"
                                    VerticalAlignment="Center" />
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock FontSize="12">
                                        <Run Text="可用 " /><Run Text="{Binding FreeSize, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock FontSize="11" Opacity="0.6">
                                        <Run Text="共 " /><Run Text="{Binding TotalSize, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 快速统计 -->
            <TextBlock Text="快速统计" FontSize="16" FontWeight="SemiBold" Margin="0,12,0,8" />
            <UniformGrid Columns="3">
                <Border
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="4"
                    Padding="16"
                    Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding FeatureCountText}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Text="Windows 功能" Opacity="0.6" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="4"
                    Padding="16"
                    Margin="4,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding DriverCountText}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Text="已安装驱动" Opacity="0.6" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="4"
                    Padding="16"
                    Margin="8,0,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding PackageCountText}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Text="更新包" Opacity="0.6" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 加载状态条 -->
            <Border
                Margin="0,16,0,0"
                Padding="12,8"
                CornerRadius="4"
                Background="{DynamicResource CardBackground}"
                Visibility="{Binding IsDismLoading, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Text="{Binding LoadingStatus}"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Opacity="0.8"
                        Margin="0,0,12,0" />
                    <ProgressBar
                        Grid.Column="1"
                        IsIndeterminate="True"
                        Height="4"
                        VerticalAlignment="Center" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
