<Page
    x:Class="DismSharp.UI.Views.ContextMenuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:DismSharp.UI.Controls"
    Title="右键菜单管理"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ScrollViewer.CanContentScroll="False">

    <Grid Margin="24">
        <controls:LoadingOverlay
            IsLoading="{Binding IsLoading}"
            LoadingStatus="{Binding LoadingStatus}" />

        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
            <StackPanel>
                <TextBlock Text="右键菜单管理" FontSize="28" FontWeight="SemiBold" />
                <TextBlock FontSize="14" Margin="0,4,0,0" Opacity="0.6">
                    <Run Text="共 " /><Run Text="{Binding TotalCount, Mode=OneWay}" /><Run Text=" 个菜单项" />
                </TextBlock>

                <ui:TextBox
                    PlaceholderText="搜索菜单项..."
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    Margin="0,12,0,0"
                    Icon="{ui:SymbolIcon Search24}" />

                <controls:StatusBar
                    StatusMessage="{Binding StatusMessage}"
                    IsStatusError="{Binding IsStatusError}"
                    IsOperating="{Binding IsOperating}"
                    OperationProgress="{Binding OperationProgress}" />

                <ItemsControl ItemsSource="{Binding FilteredItems}" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10" Margin="0,0,0,4"
                                    Background="{DynamicResource CardBackground}" CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="14" />
                                            <TextBlock Text="{Binding FileType}" Opacity="0.5" FontSize="11" Margin="8,2,0,0" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Command}" Opacity="0.6" FontSize="11" Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="600" />
                                        <TextBlock Text="{Binding KeyPath}" Opacity="0.4" FontSize="10" Margin="0,2,0,0" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ui:Button Content="禁用" Appearance="Danger" FontSize="12" Padding="10,4"
                                                   Command="{Binding DataContext.DisableItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                   CommandParameter="{Binding}" />
                                        <ui:Button Content="删除" Appearance="Secondary" FontSize="12" Padding="10,4" Margin="4,0,0,0"
                                                   Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                   CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
