<Page
    x:Class="DismSharp.UI.Views.DriversPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="驱动管理"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid Margin="24">
        <!-- 加载中覆盖层 -->
        <StackPanel
            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="10">
            <ui:ProgressRing IsIndeterminate="True" HorizontalAlignment="Center" />
            <TextBlock
                Text="{Binding LoadingStatus}"
                HorizontalAlignment="Center"
                Margin="0,12,0,0"
                FontSize="13"
                Opacity="0.7" />
        </StackPanel>

        <!-- 主内容 -->
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="驱动管理" FontSize="28" FontWeight="SemiBold" />

                <!-- 工具栏：搜索 + 备份按钮 + 切换 -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox
                        PlaceholderText="搜索驱动..."
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Icon="{ui:SymbolIcon Search24}" />
                    <ui:Button
                        Grid.Column="1"
                        Content="备份第三方驱动"
                        Icon="{ui:SymbolIcon ArrowDownload24}"
                        Appearance="Primary"
                        Margin="12,0,0,0"
                        Command="{Binding BackupDriversCommand}"
                        IsEnabled="{Binding IsOperating, Converter={StaticResource InverseBool}}" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="显示所有驱动" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ui:ToggleSwitch IsChecked="{Binding ShowAllDrivers}" />
                    </StackPanel>
                </Grid>

                <!-- 操作状态 -->
                <ui:InfoBar
                    Title="{Binding StatusMessage}"
                    IsOpen="True"
                    Severity="Informational"
                    Margin="0,8,0,0"
                    Visibility="{Binding StatusMessage, TargetNullValue=Collapsed}" />

                <ProgressBar
                    Value="{Binding OperationProgress}"
                    Maximum="100"
                    Margin="0,8,0,0"
                    Visibility="{Binding IsOperating, Converter={StaticResource BoolToVisibility}}" />

                <!-- 统计卡片 -->
                <UniformGrid Columns="4" Margin="0,12,0,0">
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="4" Padding="12,8" Margin="0,0,4,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalCount}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="总计" FontSize="11" Opacity="0.6" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="4" Padding="12,8" Margin="4,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ThirdPartyCount}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="第三方" FontSize="11" Opacity="0.6" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="4" Padding="12,8" Margin="4,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding SignedCount}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="已签名" FontSize="11" Opacity="0.6" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="4" Padding="12,8" Margin="4,0,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding UnsignedCount}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="未签名" FontSize="11" Opacity="0.6" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- 驱动列表 -->
                <ItemsControl ItemsSource="{Binding FilteredDrivers}" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,8" Margin="0,0,0,2"
                                    Background="{DynamicResource CardBackground}" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding PublishedName}" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding OriginalFileName}" FontSize="11" Opacity="0.5" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{Binding ClassName}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding ProviderName}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Text="{Binding DriverSignature, Converter={StaticResource DriverSignatureToString}}" VerticalAlignment="Center" FontSize="12" />
                                    <TextBlock Grid.Column="4" Text="{Binding DriverVersion}" VerticalAlignment="Center" FontSize="11" Opacity="0.6" HorizontalAlignment="Right" />

                                    <ui:Button
                                        Grid.Column="5"
                                        Content="删除"
                                        Appearance="Danger"
                                        FontSize="12"
                                        Padding="12,4"
                                        Margin="8,0,0,0"
                                        Visibility="{Binding InBox, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}"
                                        Command="{Binding DataContext.RemoveDriverCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
