<Page
    x:Class="DismSharp.UI.Views.AppxPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:DismSharp.UI.Controls"
    Title="Appx 管理"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ScrollViewer.CanContentScroll="False">

    <Grid Margin="24">
        <!-- Loading overlay -->
        <controls:LoadingOverlay
            IsLoading="{Binding IsLoading}"
            LoadingStatus="{Binding LoadingStatus}" />

        <!-- Main content -->
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="Appx 管理" FontSize="28" FontWeight="SemiBold" />
                <TextBlock FontSize="14" Margin="0,4,0,0" Opacity="0.6">
                    <Run Text="共 " /><Run Text="{Binding TotalCount, Mode=OneWay}" /><Run Text=" 个预配包" />
                </TextBlock>

                <!-- Search -->
                <ui:TextBox
                    PlaceholderText="搜索应用..."
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    Margin="0,12,0,0"
                    Icon="{ui:SymbolIcon Search24}" />

                <!-- Status bar -->
                <controls:StatusBar
                    StatusMessage="{Binding StatusMessage}"
                    IsStatusError="{Binding IsStatusError}"
                    IsOperating="{Binding IsOperating}"
                    OperationProgress="{Binding OperationProgress}" />

                <!-- Batch operations -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <ui:Button Content="全选/取消全选" Appearance="Secondary" FontSize="12"
                               Command="{Binding ToggleSelectAllCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="删除选中" Appearance="Danger" FontSize="12"
                               Command="{Binding DeleteSelectedAsyncCommand}"
                               IsEnabled="{Binding SelectedCount, Converter={StaticResource GreaterThanZero}}"
                               Margin="0,0,8,0" />
                    <TextBlock Text="{Binding SelectedCount, StringFormat='已选中 {0} 项'}"
                               VerticalAlignment="Center" Opacity="0.6" />
                </StackPanel>

                <!-- Package list -->
                <ItemsControl ItemsSource="{Binding SelectablePackages}" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10" Margin="0,0,0,4"
                                    Background="{DynamicResource CardBackground}" CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center" Margin="0,0,8,0" />

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Item.DisplayName}" FontWeight="Medium" FontSize="14" />
                                        <TextBlock Text="{Binding Item.PackageName}" Opacity="0.6" FontSize="12" Margin="0,2,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Item.Version}" Opacity="0.5" FontSize="11" Margin="0,0,12,0" />
                                            <TextBlock Text="{Binding Item.Architecture}" Opacity="0.5" FontSize="11" />
                                        </StackPanel>
                                    </StackPanel>

                                    <ui:Button
                                        Grid.Column="2"
                                        Content="删除"
                                        Appearance="Danger"
                                        FontSize="12"
                                        Padding="12,6"
                                        Command="{Binding DataContext.RemovePackageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding Item}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
