<Page
    x:Class="DismSharp.UI.Views.FeaturesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Windows 功能"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid Margin="24">
        <!-- 加载中覆盖层 -->
        <StackPanel
            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="10">
            <ui:ProgressRing IsIndeterminate="True" HorizontalAlignment="Center" />
            <TextBlock
                Text="{Binding LoadingStatus}"
                HorizontalAlignment="Center"
                Margin="0,12,0,0"
                FontSize="13"
                Opacity="0.7" />
        </StackPanel>

        <!-- 主内容 -->
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
            <StackPanel>
                <!-- 标题栏 -->
                <TextBlock Text="Windows 功能" FontSize="28" FontWeight="SemiBold" />
                <TextBlock FontSize="14" Margin="0,4,0,0" Opacity="0.6">
                    <Run Text="共 " /><Run Text="{Binding TotalCount, Mode=OneWay}" /><Run Text=" 个功能，" />
                    <Run Text="{Binding EnabledCount, Mode=OneWay}" /><Run Text=" 个已启用" />
                </TextBlock>

                <!-- 搜索框 -->
                <ui:TextBox
                    PlaceholderText="搜索功能..."
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    Margin="0,12,0,0"
                    Icon="{ui:SymbolIcon Search24}" />

                <!-- 操作状态 -->
                <ui:InfoBar
                    Title="{Binding StatusMessage}"
                    IsOpen="True"
                    Severity="Informational"
                    Margin="0,8,0,0"
                    Visibility="{Binding StatusMessage, TargetNullValue=Collapsed}" />

                <ProgressBar
                    Value="{Binding OperationProgress}"
                    Maximum="100"
                    Margin="0,8,0,0"
                    Visibility="{Binding IsOperating, Converter={StaticResource BoolToVisibility}}" />

                <!-- 功能列表 -->
                <ItemsControl ItemsSource="{Binding FilteredFeatures}" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,8" Margin="0,0,0,2"
                                    Background="{DynamicResource CardBackground}" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Ellipse
                                        Width="10" Height="10"
                                        Fill="{Binding State, Converter={StaticResource FeatureStateToBrush}}"
                                        VerticalAlignment="Center" />

                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding FeatureName}"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0"
                                        TextTrimming="CharacterEllipsis" />

                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{Binding State, Converter={StaticResource FeatureStateToString}}"
                                        VerticalAlignment="Center"
                                        Opacity="0.6"
                                        FontSize="12" />

                                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                                        <ui:Button
                                            Content="启用"
                                            Appearance="Primary"
                                            FontSize="12"
                                            Padding="12,4"
                                            Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}"
                                            Command="{Binding DataContext.EnableFeatureCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                        <ui:Button
                                            Content="禁用"
                                            Appearance="Danger"
                                            FontSize="12"
                                            Padding="12,4"
                                            Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibility}}"
                                            Command="{Binding DataContext.DisableFeatureCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
