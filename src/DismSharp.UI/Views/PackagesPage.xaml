<Page
    x:Class="DismSharp.UI.Views.PackagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="更新包管理"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ScrollViewer.CanContentScroll="False">

    <Grid Margin="24">
        <!-- 加载中覆盖层 -->
        <StackPanel
            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="10">
            <ui:ProgressRing IsIndeterminate="True" HorizontalAlignment="Center" />
            <TextBlock
                Text="{Binding LoadingStatus}"
                HorizontalAlignment="Center"
                Margin="0,12,0,0"
                FontSize="13"
                Opacity="0.7" />
        </StackPanel>

        <!-- 主内容 -->
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="更新包管理" FontSize="28" FontWeight="SemiBold" />
                <TextBlock FontSize="14" Margin="0,4,0,0" Opacity="0.6">
                    <Run Text="共 " /><Run Text="{Binding TotalCount, Mode=OneWay}" /><Run Text=" 个更新包" />
                </TextBlock>

                <!-- 搜索框 -->
                <ui:TextBox
                    PlaceholderText="搜索更新包..."
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    Margin="0,12,0,0"
                    Icon="{ui:SymbolIcon Search24}" />

                <!-- 操作状态 -->
                <ui:InfoBar
                    Title="{Binding StatusMessage}"
                    IsOpen="True"
                    Severity="Informational"
                    Margin="0,8,0,0"
                    Visibility="{Binding StatusMessage, TargetNullValue=Collapsed}" />

                <ProgressBar
                    Value="{Binding OperationProgress}"
                    Maximum="100"
                    Margin="0,8,0,0"
                    Visibility="{Binding IsOperating, Converter={StaticResource BoolToVisibility}}" />

                <!-- 包列表 -->
                <ItemsControl ItemsSource="{Binding FilteredPackages}" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" Margin="0,0,0,2"
                                    Background="{DynamicResource CardBackground}" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding PackageName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="12" />
                                    <TextBlock Grid.Column="1" Text="{Binding PackageState, Converter={StaticResource FeatureStateToString}}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                                    <TextBlock Grid.Column="2" Text="{Binding ReleaseType, Converter={StaticResource ReleaseTypeToString}}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                                    <TextBlock Grid.Column="3" Text="{Binding InstallTime, StringFormat=yyyy-MM-dd}" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />

                                    <ui:Button
                                        Grid.Column="4"
                                        Content="卸载"
                                        Appearance="Danger"
                                        FontSize="12"
                                        Padding="12,4"
                                        Command="{Binding DataContext.UninstallPackageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
