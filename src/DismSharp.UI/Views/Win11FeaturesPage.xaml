<Page
    x:Class="DismSharp.UI.Views.Win11FeaturesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:DismSharp.UI.Controls"
    Title="Win11 功能"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ScrollViewer.CanContentScroll="False">

    <Grid Margin="24">
        <controls:LoadingOverlay
            IsLoading="{Binding IsLoading}"
            LoadingStatus="{Binding LoadingStatus}" />

        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
            <StackPanel>
                <TextBlock Text="Win11 功能管理" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="管理 Windows 11 新特性" FontSize="14" Margin="0,4,0,0" Opacity="0.6" />

                <controls:StatusBar
                    StatusMessage="{Binding StatusMessage}"
                    IsStatusError="{Binding IsStatusError}"
                    IsOperating="{Binding IsOperating}"
                    OperationProgress="{Binding OperationProgress}" />

                <!-- Widgets -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="16" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="小组件" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="启用小组件功能" Opacity="0.7" />
                                <TextBlock Text="在任务栏显示小组件按钮" Opacity="0.7" Margin="0,8,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:ToggleSwitch IsChecked="{Binding IsWidgetsEnabled}" Checked="ToggleWidgets_Checked" Unchecked="ToggleWidgets_Unchecked" />
                                <ui:ToggleSwitch IsChecked="{Binding IsWidgetsTaskbarEnabled}" Checked="ToggleWidgetsTaskbar_Checked" Unchecked="ToggleWidgetsTaskbar_Unchecked" Margin="16,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Copilot -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="16" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Copilot" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="启用 Copilot" Opacity="0.7" />
                                <TextBlock Text="在任务栏显示 Copilot 按钮" Opacity="0.7" Margin="0,8,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:ToggleSwitch IsChecked="{Binding IsCopilotEnabled}" Checked="ToggleCopilot_Checked" Unchecked="ToggleCopilot_Unchecked" />
                                <ui:ToggleSwitch IsChecked="{Binding IsCopilotTaskbarEnabled}" Checked="ToggleCopilotTaskbar_Checked" Unchecked="ToggleCopilotTaskbar_Unchecked" Margin="16,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- WSL -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="16" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="WSL2 Linux 子系统" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding WslDistros}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8" Margin="0,0,0,4" Background="{DynamicResource CardBackgroundFillColorSecondary}" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Medium" />
                                                    <TextBlock Text="(默认)" Opacity="0.5" Margin="8,0,0,0" Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibility}}" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding State}" Opacity="0.6" FontSize="12" />
                                                    <TextBlock Text=" | WSL " Opacity="0.6" FontSize="12" />
                                                    <TextBlock Text="{Binding Version}" Opacity="0.6" FontSize="12" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <ui:Button Content="终止" Appearance="Secondary" FontSize="11" Padding="8,4"
                                                           Command="{Binding DataContext.TerminateWslCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}" />
                                                <ui:Button Content="设为默认" Appearance="Secondary" FontSize="11" Padding="8,4" Margin="4,0,0,0"
                                                           Command="{Binding DataContext.SetDefaultWslCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}" />
                                                <ui:Button Content="卸载" Appearance="Danger" FontSize="11" Padding="8,4" Margin="4,0,0,0"
                                                           Command="{Binding DataContext.UninstallWslCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- WSA -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="16" Margin="0,12,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="WSA Android 子系统" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding IsWsaInstalled, StringFormat='{}({0})', Converter={StaticResource BoolToInstalledString}}" Opacity="0.6" Margin="8,4,0,0" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding WsaApps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8" Margin="0,0,0,4" Background="{DynamicResource CardBackgroundFillColorSecondary}" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="Medium" />
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding Version}" Opacity="0.6" FontSize="12" />
                                                </StackPanel>
                                            </StackPanel>
                                            <ui:Button Grid.Column="1" Content="卸载" Appearance="Danger" FontSize="11" Padding="8,4"
                                                       Command="{Binding DataContext.UninstallWsaAppCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
