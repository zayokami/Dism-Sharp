<Page
    x:Class="DismSharp.UI.Views.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="系统清理"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ScrollViewer.CanContentScroll="False">

    <Grid Margin="24">
        <!-- 扫描中覆盖层 -->
        <StackPanel
            Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="10">
            <ui:ProgressRing IsIndeterminate="True" HorizontalAlignment="Center" />
            <TextBlock
                Text="{Binding ScanStatus}"
                HorizontalAlignment="Center"
                Margin="0,12,0,0"
                FontSize="13"
                Opacity="0.7" />
            <ProgressBar
                Value="{Binding OperationProgress}"
                Maximum="100"
                Margin="0,12,0,0"
                Width="300" />
        </StackPanel>

        <!-- 主内容 -->
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="系统清理" FontSize="28" FontWeight="SemiBold" />
                <TextBlock FontSize="14" Margin="0,4,0,0" Opacity="0.6"
                           Text="扫描并清理系统中的临时文件、缓存、日志等，释放磁盘空间" />

                <!-- 操作按钮区域 -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ui:Button
                        Content="扫描"
                        Icon="{ui:SymbolIcon Search24}"
                        Appearance="Primary"
                        Command="{Binding ScanCommand}"
                        IsEnabled="{Binding IsCleaning, Converter={StaticResource InverseBool}}" />

                    <ui:Button
                        Grid.Column="1"
                        Content="开始清理"
                        Icon="{ui:SymbolIcon Delete24}"
                        Appearance="Danger"
                        Margin="8,0,0,0"
                        Command="{Binding CleanCommand}"
                        IsEnabled="{Binding HasScanned}" />

                    <!-- 统计信息 -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding HasScanned, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="已选: " Opacity="0.6" />
                        <TextBlock Text="{Binding TotalFileCount}" FontWeight="SemiBold" />
                        <TextBlock Text=" 个文件, " Opacity="0.6" />
                        <TextBlock Text="{Binding TotalSizeText}" FontWeight="SemiBold" Foreground="#E74C3C" />
                    </StackPanel>
                </Grid>

                <!-- 操作状态 -->
                <ui:InfoBar
                    Title="{Binding StatusMessage}"
                    IsOpen="True"
                    Severity="Informational"
                    Margin="0,8,0,0"
                    Visibility="{Binding StatusMessage, TargetNullValue=Collapsed}" />

                <ProgressBar
                    Value="{Binding OperationProgress}"
                    Maximum="100"
                    Margin="0,8,0,0"
                    Visibility="{Binding IsCleaning, Converter={StaticResource BoolToVisibility}}" />

                <!-- 未扫描提示 -->
                <Border
                    Visibility="{Binding HasScanned, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}"
                    Background="{DynamicResource CardBackground}"
                    CornerRadius="8"
                    Padding="32"
                    Margin="0,24,0,0"
                    HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="SearchInfo24" FontSize="48" HorizontalAlignment="Center" Opacity="0.3" />
                        <TextBlock
                            Text="点击「扫描」按钮开始分析可清理的文件"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0"
                            FontSize="14"
                            Opacity="0.5" />
                    </StackPanel>
                </Border>

                <!-- 清理规则列表 -->
                <ItemsControl
                    ItemsSource="{Binding RuleItems}"
                    Margin="0,12,0,0"
                    Visibility="{Binding HasScanned, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="12,10"
                                Margin="0,0,0,4"
                                Background="{DynamicResource CardBackground}"
                                CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox
                                        IsChecked="{Binding IsSelected}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="14" />
                                        <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.5" Margin="0,2,0,0" />
                                    </StackPanel>

                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Opacity="0.6"
                                        Margin="12,0">
                                        <Run Text="{Binding FileCount, Mode=OneWay}" />
                                        <Run Text=" 个文件" />
                                    </TextBlock>

                                    <TextBlock
                                        Grid.Column="3"
                                        Text="{Binding SizeText}"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        FontSize="14"
                                        MinWidth="80"
                                        TextAlignment="Right" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
